<!DOCTYPE html>
<html>
<head>
  <style>
    body { font-family: -apple-system, sans-serif; margin: 0; padding: 20px; background: #f5f5f5; }
    .container { max-width: 600px; margin: 0 auto; background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    .header { padding: 20px; color: white; }
    .header.minor { background: #3b82f6; }
    .header.moderate { background: #f59e0b; }
    .header.severe { background: #f97316; }
    .header.critical { background: #ef4444; }
    .header h1 { margin: 0; font-size: 20px; }
    .body { padding: 20px; }
    .detail-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #eee; }
    .label { color: #666; }
    .value { font-weight: 600; }
    .footer { padding: 15px 20px; background: #f9f9f9; font-size: 12px; color: #999; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header {{ severity }}">
      <h1>ACRAS Alert: {{ severity | upper }} {{ incident_type | title }}</h1>
    </div>
    <div class="body">
      <div class="detail-row">
        <span class="label">Location</span>
        <span class="value">{{ interstate }}{% if direction %} {{ direction }}{% endif %}</span>
      </div>
      <div class="detail-row">
        <span class="label">Detected At</span>
        <span class="value">{{ detected_at }}</span>
      </div>
      <div class="detail-row">
        <span class="label">Confidence</span>
        <span class="value">{{ "%.0f" | format(confidence * 100) }}%</span>
      </div>
      {% if vehicle_count %}
      <div class="detail-row">
        <span class="label">Vehicles</span>
        <span class="value">{{ vehicle_count }}</span>
      </div>
      {% endif %}
      {% if summary %}
      <p>{{ summary }}</p>
      {% endif %}
    </div>
    <div class="footer">
      This alert was automatically generated by ACRAS.
    </div>
  </div>
</body>
</html>
