# Database
DATABASE_URL=postgresql+asyncpg://acras:acras@postgres:5432/acras
DATABASE_SYNC_URL=postgresql://acras:acras@postgres:5432/acras

# Redis
REDIS_URL=redis://redis:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000

# ML Models
YOLO_MODEL_PATH=yolov8s.pt
YOLO_CONFIDENCE_THRESHOLD=0.5
CRASH_CLASSIFIER_PATH=models/crash_classifier.pt
CRASH_CONFIDENCE_THRESHOLD=0.7
SEVERITY_MODEL_PATH=models/severity_model.pt

# Processing
FRAME_EXTRACTION_FPS=1
MAX_CONCURRENT_CAMERAS=100
FRAME_BUFFER_SIZE=100

# Weather
OPENWEATHER_API_KEY=your-key-here
WEATHER_CACHE_TTL_SECONDS=600

# Alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASSWORD=your-app-password
TWILIO_ACCOUNT_SID=optional
TWILIO_AUTH_TOKEN=optional
TWILIO_FROM_NUMBER=optional

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/ws

# Monitoring
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO
LOG_FORMAT=json
